# Godot editor cache (fully regenerated on project open)
.godot/

# Godot 4.x UID files (auto-generated, not needed in source control)
*.uid

# Export presets contain local absolute paths — never commit
export_presets.cfg

# Mono / C# build artifacts
.mono/
data_*/
mono_crash.*.json

# Godot per-asset import metadata (regenerated by the editor)
**/.import/
*.import

# OS-generated junk
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Player save data (local runtime file, not source)
*.save
save_data.json

# Logs
logs/
*.log

# Build / export output
build/
export/
dist/

# VS Code
.vscode/

# JetBrains IDEs
.idea/

# Python (if used for tooling/placeholder scripts)
__pycache__/
*.pyc
*.pyo
